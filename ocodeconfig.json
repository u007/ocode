{
  "advisor": {
    "enabled": false,
    "provider": "openai",
    "model": "gpt-5.4-mini"
  },
  "compact": {
    "enabled": true,
    "summary_provider": "",
    "summary_model": "",
    "token_threshold": 0.85,
    "keep_recent_turns": 3,
    "min_messages": 8,
    "summary_timeout_seconds": 90,
    "summary_max_retries": 1,
    "max_summary_input_tokens": 50000
  },
  "editor": "cat",
  "ide_mode": "off",
  "last_model": "gpt-4o-mini",
  "last_thinking_budget": 16000,
  "permissions": {
    "mode": "normal",
    "tools": {
      "advisor": "allow",
      "agent": "ask",
      "agent_status": "allow",
      "apply_patch": "allow",
      "ast": "allow",
      "bash": "ask",
      "bash_output": "allow",
      "delete": "ask",
      "edit": "allow",
      "format": "allow",
      "glob": "allow",
      "grep": "allow",
      "kill_shell": "allow",
      "list": "allow",
      "lsp": "allow",
      "lsp_diagnostics": "allow",
      "mcp_*": "ask",
      "multi_edit": "allow",
      "multi_file_edit": "allow",
      "multiedit": "allow",
      "plan_enter": "allow",
      "plan_exit": "allow",
      "question": "allow",
      "read": "allow",
      "replace_lines": "allow",
      "repo_clone": "ask",
      "repo_overview": "allow",
      "skill": "allow",
      "task": "allow",
      "task_status": "allow",
      "todoread": "allow",
      "todowrite": "allow",
      "wait": "allow",
      "webfetch": "ask",
      "websearch": "ask",
      "write": "allow"
    },
    "bash": {
      "prefixes": {
        "1": "allow",
        "grep": "allow",
        "just": "allow"
      },
      "auto_allow_prefixes": [
        "stat",
        "yq",
        "basename",
        "shasum",
        "jq",
        "cmp",
        "unexpand",
        "diff",
        "awk",
        "more",
        "fold",
        "xxd",
        "sort",
        "od",
        "strings",
        "dirname",
        "tail",
        "cut",
        "ls",
        "cksum",
        "du",
        "tr",
        "tac",
        "comm",
        "find",
        "expand",
        "rg",
        "tree",
        "sha1sum",
        "nl",
        "wc",
        "md5sum",
        "sha256sum",
        "fd",
        "cd",
        "rev",
        "realpath",
        "readlink",
        "hexdump",
        "less",
        "uniq",
        "file",
        "join",
        "paste",
        "column",
        "cat",
        "sha512sum",
        "sed",
        "head",
        "ag",
        "grep"
      ],
      "prefix_modes": {
        "ag": "read_only",
        "awk": "read_only",
        "basename": "read_only",
        "cat": "read_only",
        "cd": "read_only",
        "cksum": "read_only",
        "cmp": "read_only",
        "column": "read_only",
        "comm": "read_only",
        "cut": "read_only",
        "diff": "read_only",
        "dirname": "read_only",
        "du": "read_only",
        "expand": "read_only",
        "fd": "read_only",
        "file": "read_only",
        "find": "read_only",
        "fold": "read_only",
        "grep": "read_only",
        "head": "read_only",
        "hexdump": "read_only",
        "join": "read_only",
        "jq": "read_only",
        "less": "read_only",
        "ls": "read_only",
        "md5sum": "read_only",
        "more": "read_only",
        "nl": "read_only",
        "od": "read_only",
        "paste": "read_only",
        "readlink": "read_only",
        "realpath": "read_only",
        "rev": "read_only",
        "rg": "read_only",
        "sed": "mutating",
        "sha1sum": "read_only",
        "sha256sum": "read_only",
        "sha512sum": "read_only",
        "shasum": "read_only",
        "sort": "read_only",
        "stat": "read_only",
        "strings": "read_only",
        "tac": "read_only",
        "tail": "read_only",
        "tr": "read_only",
        "tree": "read_only",
        "unexpand": "read_only",
        "uniq": "read_only",
        "wc": "read_only",
        "xxd": "read_only",
        "yq": "read_only"
      }
    },
    "auto": {
      "enabled": true,
      "model": "openrouter/openrouter/free",
      "allow_destructive": true,
      "prompt": "keep me",
      "max_context_bytes": 4096,
      "max_context_sources": 2,
      "max_context_lines_per_source": 80
    }
  },
  "small_model": "deepseek/deepseek-v4-flash",
  "tui": {
    "theme": "amoled",
    "mouse": true,
    "scroll_speed": 3,
    "keybinds": {},
    "leader_timeout": 2000,
    "branchless": false
  }
}
